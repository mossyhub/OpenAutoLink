# openautolink.env — Configuration for OpenAutoLink bridge relay
# Place in /etc/openautolink.env or /boot/firmware/openautolink.env
#
# The relay is a thin TCP splice — it bridges the phone's AA connection
# to the car app. All AA settings (resolution, codec, DPI, etc.) are
# configured in the car app, not here.

# ── Car Network Mode ──────────────────────────────────────────────────
# How the bridge connects to the car's head unit:
#   external-nic — Onboard eth0 connects to car via USB Ethernet adapter.
#                  This is the tested and supported mode.
#   auto         — (Experimental) Try USB gadget first, fall back to eth0.
#   usb-gadget   — (Experimental) Force USB gadget only.
OAL_CAR_NET_MODE=external-nic

# USB gadget protocol for car communication:
#   rndis   — RNDIS (most compatible with Android/Windows hosts, recommended)
#   ecm     — CDC-ECM (standard Linux ethernet-over-USB, less compatible)
#   ncm     — CDC-NCM (newer, better performance, requires kernel support)
OAL_CAR_NET_PROTO=rndis

# Seconds to wait for USB gadget carrier (car detecting the device).
# Only used in 'auto' mode. If carrier doesn't come up, falls back to eth0.
OAL_CAR_NET_GADGET_TIMEOUT=10

# Include mass_storage (UDisk) in USB gadget composite device.
# Required for GM EVs to avoid "unsupported device" popup.
# Set to 0 if your car doesn't need it.
OAL_CAR_NET_UDISK=1

# ── Car Network ───────────────────────────────────────────────────────
# Static IP for the bridge's car-facing NIC.
# Set on eth0 (onboard NIC connected to car via USB Ethernet adapter).
# The car app connects to this IP.
OAL_CAR_NET_IP=192.168.222.222
OAL_CAR_NET_MASK=24

# ── SSH/Management Network ────────────────────────────────────────────
# The NIC not used for car gets SSH access. Mode:
#   dhcp-client (default) — get IP from whatever provides DHCP
#     Works with laptop WiFi sharing (ICS), routers, etc.
#   static — set a fixed IP, no DHCP client or server
#     Use with laptop ICS when you want a known IP on the bridge.
#   dhcp-server — run DHCP server on the SSH NIC for direct connections
#     Use when connecting a laptop directly without any DHCP source.
OAL_SSH_MODE=dhcp-client
#OAL_SSH_IP=192.168.137.2
OAL_SSH_DHCP_START=10.0.0.10
OAL_SSH_DHCP_END=10.0.0.50

# ── Phone Connection Mode ─────────────────────────────────────────────
# How the phone connects to the bridge:
#   wireless  — Phone connects via WiFi (needs WiFi module on SBC)
#   usb       — Phone plugs into SBC USB host port (wired Android Auto)
# Wired mode is useful for SBCs without WiFi (e.g., ROCK 3A without WiFi module).
OAL_PHONE_MODE=wireless

# ── Wireless Android Auto ────────────────────────────────────────────
OAL_WIRELESS_ENABLE=1
# WiFi interface name (empty = auto-detect: checks wlan0, wlp*, etc.)
# Set explicitly only if auto-detection picks the wrong interface.
OAL_WIRELESS_INTERFACE=
# Band preference: 5ghz (preferred, auto-probes channels) or 24ghz (fallback)
# The script probes hardware capabilities and picks the best available config.
# 5GHz gives lower latency; falls back to 2.4GHz if hardware doesn't support it.
OAL_WIRELESS_BAND=5ghz
# Override channel (empty = auto-select best DFS-free channel for the band)
# For 5GHz: 36, 40, 44, 48, 149, 153, 157, 161 (DFS-free)
# For 2.4GHz: 1, 6, 11
OAL_WIRELESS_CHANNEL=
# Country code for regulatory domain (affects available channels)
OAL_WIRELESS_COUNTRY=US
# SSID/password — auto-generated from MAC if empty
OAL_WIRELESS_SSID=
OAL_WIRELESS_PASSWORD=
OAL_WIRELESS_RFCOMM_CHANNEL=8

# ── Bluetooth ─────────────────────────────────────────────────────────
# BT MAC address sent to phone for auto-pairing via Android Auto.
# Leave empty for auto-detection (tries sysfs, hciconfig, bluetoothctl).
# Set manually if auto-detect fails on your SBC.
# Format: XX:XX:XX:XX:XX:XX (uppercase, colon-separated)
OAL_BT_MAC=

# Preferred phone MAC for wireless AA auto-reconnect.
# Leave empty to fall back to the first paired phone the bridge finds.
# Set by the app's Default Phone setting.
OAL_DEFAULT_PHONE_MAC=

# ── mDNS Discovery ───────────────────────────────────────────────────
# The bridge advertises _openautolink._tcp via Avahi for automatic
# discovery by the car's app.
OAL_MDNS_ENABLE=1

# ── Debug ─────────────────────────────────────────────────────────────
OAL_LOGFILE=/var/log/openautolink.log
