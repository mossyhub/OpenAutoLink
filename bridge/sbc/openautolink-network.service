[Unit]
Description=OpenAutoLink Network Setup (car + SSH)
DefaultDependencies=no
Before=openautolink.service
After=local-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=-/etc/openautolink.env
EnvironmentFile=-/boot/firmware/openautolink.env
ExecStart=/opt/openautolink/setup-network.sh setup
ExecStop=/opt/openautolink/setup-network.sh teardown

[Install]
WantedBy=multi-user.target
