[Unit]
Description=OpenAutoLink Car Network Setup
DefaultDependencies=no
Before=openautolink.service
After=local-fs.target

[Service]
Type=oneshot
RemainAfterExit=yes
EnvironmentFile=-/etc/openautolink.env
EnvironmentFile=-/boot/firmware/openautolink.env
ExecStart=/opt/openautolink/setup-car-net.sh setup
ExecStop=/opt/openautolink/setup-car-net.sh teardown

[Install]
WantedBy=multi-user.target
